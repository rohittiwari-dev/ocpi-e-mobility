{
  "name": "ocpi-ts-sdk",
  "version": "0.1.0",
  "description": "Strictly-typed Zod schemas and REST client for OCPI 2.1.1, 2.2.1, and 3.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.cjs"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "import": "./dist/schemas/index.js",
      "require": "./dist/schemas/index.cjs"
    },
    "./modules": {
      "types": "./dist/modules/index.d.ts",
      "import": "./dist/modules/index.js",
      "require": "./dist/modules/index.cjs"
    },
    "./locations": {
      "types": "./dist/schemas/locations.d.ts",
      "import": "./dist/schemas/locations.js",
      "require": "./dist/schemas/locations.cjs"
    },
    "./sessions": {
      "types": "./dist/schemas/sessions.d.ts",
      "import": "./dist/schemas/sessions.js",
      "require": "./dist/schemas/sessions.cjs"
    },
    "./cdrs": {
      "types": "./dist/schemas/cdrs.d.ts",
      "import": "./dist/schemas/cdrs.js",
      "require": "./dist/schemas/cdrs.cjs"
    },
    "./tariffs": {
      "types": "./dist/schemas/tariffs.d.ts",
      "import": "./dist/schemas/tariffs.js",
      "require": "./dist/schemas/tariffs.cjs"
    },
    "./tokens": {
      "types": "./dist/schemas/tokens.d.ts",
      "import": "./dist/schemas/tokens.js",
      "require": "./dist/schemas/tokens.cjs"
    },
    "./commands": {
      "types": "./dist/schemas/commands.d.ts",
      "import": "./dist/schemas/commands.js",
      "require": "./dist/schemas/commands.cjs"
    },
    "./credentials": {
      "types": "./dist/schemas/credentials.d.ts",
      "import": "./dist/schemas/credentials.js",
      "require": "./dist/schemas/credentials.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}
